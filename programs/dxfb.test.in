#    rel="$(dirname $d)"
#    dwg="$DATADIR/$d.dwg"
#    tgt="../${base}_${rel}"
#    log="$tgt.dxf.log"
#    rm "./$log" 2>/dev/null
#    check_roundtrip
#done

if test "0" = "$i" ; then
    rm ./*.dxb.log 2>/dev/null
    exit 0
else
    echo "$(basename "$0"): $i failures"
    ls -l ./*dxb.log
    exit 1
fi
